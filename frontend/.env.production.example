# =============================================================================
# PingCode Agent - Frontend 生产环境
# =============================================================================
# 复制为 .env.production，pnpm build 时自动加载
# 同源部署时 VITE_API_BASE_URL 建议为空或相对路径，由后端托管静态资源
# =============================================================================

# 同源部署时留空，API 使用相对路径 /api；反向代理/分离部署时填写实际后端地址
VITE_API_BASE_URL=

# 生产环境标题
VITE_APP_TITLE=PingCode 需求智能分析
