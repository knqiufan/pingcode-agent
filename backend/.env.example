# =============================================================================
# PingCode Agent - Backend 环境指向
# =============================================================================
# 本文件仅指定当前运行环境，决定加载哪个环境配置：
#   NODE_ENV=development -> 加载 .env.development
#   NODE_ENV=production  -> 加载 .env.production
#
# 使用方式：
#   1. 复制本文件为 .env
#   2. 复制 .env.development.example 为 .env.development（本地开发）
#   3. 复制 .env.production.example 为 .env.production（生产部署）
# 所有具体配置项（PORT、CORS、JWT、PingCode、SeekDB 等）仅写在对应环境的文件中。
# =============================================================================

NODE_ENV=development
