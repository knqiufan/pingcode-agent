# =============================================================================
# PingCraft - Backend 生产环境配置
# =============================================================================
# 复制为 .env.production；NODE_ENV=production 时加载，docker-compose 也可通过 env_file 引用
# 部署前必须：1) 配置强随机 JWT_SECRET  2) 确保 SEEKDB_* 与部署环境一致
# =============================================================================

# ---------- 应用 ----------
NODE_ENV=production
PORT=3000

# ---------- CORS 与前端地址（同源部署时与对外域名一致） ----------
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ---------- JWT 鉴权（必须修改为强随机值） ----------
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---------- PingCode OAuth（PINGCODE_HOST 必填，部署时改为实际 PingCode 根 URL） ----------
PINGCODE_REDIRECT_URI=http://localhost:3000/auth/callback
PINGCODE_HOST=http://your-pingcode-host:port

# ---------- SeekDB（docker-compose 中常覆盖为 SEEKDB_HOST=seekdb） ----------
SEEKDB_HOST=seekdb
SEEKDB_PORT=2881
SEEKDB_USER=root
SEEKDB_PASSWORD=
SEEKDB_DATABASE=pingcode_agent
SEEKDB_RETRY_COUNT=5
SEEKDB_RETRY_INTERVAL_MS=2000

# ---------- 同步工作项批处理（可选） ----------
SYNC_WORK_ITEM_BATCH_SIZE=25
SYNC_BATCH_DELAY_MS=500
